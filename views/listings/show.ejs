<% layout("/layouts/boilerplate") %>

<div class="row">
  <div class="col-8 offset-2">
    <h1>Listing Details</h1>
    <div class="card">
      <img
        src="<%= listing.image %>"
        class="card-img-top show-image"
        alt="listing_image"
      />
      <div class="card-body">
        <p class="card-text">
          <b><%= listing.title %></b> <br />
          <%= listing.description %> <br />
          &#8377;<%= listing.price.toLocaleString("en-IN") %> <br />
          <%= listing.location %> <br />
          <%= listing.country %> <br />
        </p>
      </div>
    </div>

    <div class="btns">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark mb-2"
        >Edit Your Listing</a
      >

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark delete-btn mb-3">
          Delete this listing
        </button>
      </form>
    </div>
  </div>
</div>
